{
    "name": "local/container-bench",
    "description": "PHP Dependency Injection container benchmarks",
    "license": "MIT",
    "require": {
        "php": "^8.5",
        "illuminate/container": "^12.54",
        "nih/container": "^0.1.3",
        "php-di/php-di": "^7.1",
        "phpbench/phpbench": "^1.5",
        "psr/container": "^2.0",
        "spiral/core": "^3.16",
        "symfony/config": "^8.0",
        "symfony/dependency-injection": "^8.0",
        "yiisoft/di": "^1.4",
        "yiisoft/factory": "^1.3"
    },
    "autoload": {
        "psr-4": {
            "Bench\\": "app"
        }
    },
    "require-dev": {
        "symfony/var-dumper": "^8.0"
    },
    "config": {
        "sort-packages": true
    },
    "scripts": {
        "bench": "phpbench run --report=grouped"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
